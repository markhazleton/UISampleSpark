{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CsvOutputFolder": "c:\\temp\\WebSpark\\CsvOutput",
  "HttpRequestResultPollyOptions": {
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 1,
    "CircuitBreakerThreshold": 3,
    "CircuitBreakerDurationSeconds": 10
  },
  "profiles": {
    "IIS Express": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "launchUrl": "https://localhost:7023/",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_SYSTEM_NET_HTTP_USESOCKETSHTTPHANDLER": "0"
      }
    }
  },
  "Swagger": {
    "XmlFile": "UISampleSpark.UI.xml",
    "ApiVersion": "v1",
    "ApiTitle": "UI Sample Spark",
    "ApiDescription": "Simple RESTful API built with ASP.NET 10.0 to show how to create RESTful services using a decoupled, maintainable architecture.",
    "UserProfile": {
      "Name": "Mark Hazleton",
      "Url": "https://markhazleton.com/",
      "Email": "mark.hazleton@controlorigins.com"
    }
  },
  "ApiSecurity": {
    "RequireApiKey": true,
    "ApiKeys": [
      "contact-mark-for-api-key-01",
      "contact-mark-for-api-key-02",
      "contact-mark-for-api-key-03",
      "contact-mark-for-api-key-04",
      "contact-mark-for-api-key-05",
      "contact-mark-for-api-key-06",
      "contact-mark-for-api-key-07",
      "contact-mark-for-api-key-08",
      "contact-mark-for-api-key-09",
      "contact-mark-for-api-key-10"
    ]
  }
}
